        "company": {
          "type": "string"
        },
        "authorRole": {
          "type": "string"
        },
        "avatarUrl": {
          "type": "string"
        },
        "isVisible": {
          "type": "boolean"
        },
        "order": {
          "type": "number"
        }
      },
      "required": [
        "quote",
        "authorName",
        "company",
        "isVisible",
        "order"
      ]
    },
    "Message": {
      "title": "Message",
      "description": "Contact form submissions",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "subject": {
          "type": "string"
        },
        "budget": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
