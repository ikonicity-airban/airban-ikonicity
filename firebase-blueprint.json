{
  "entities": {
    "Availability": {
      "title": "Availability",
      "description": "Portfolios availability status indicator",
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "status",
        "message",
        "updatedAt"
      ]
    },
    "Project": {
      "title": "Project",
      "description": "Portfolio project item",
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "slug": {
          "type": "string"
        },
        "imageUrl": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "liveUrl": {
          "type": "string"
        },
        "repoUrl": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "longDesc": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "year": {
          "type": "string"
        },
        "stack": {
          "type": "array"
        },
        "featured": {
          "type": "boolean"
        },
        "isVisible": {
          "type": "boolean"
        },
        "order": {
          "type": "number"
        }
      },
      "required": [
        "title",
        "slug",
        "imageUrl",
        "featured",
        "isVisible",
        "order"
      ]
