  "firestore": {
    "availability": {
      "schema": "Availability",
      "description": "Global status configuration"
    },
    "projects": {
      "schema": "Project",
      "description": "List of portfolio projects"
    },
    "testimonials": {
      "schema": "Testimonial",
      "description": "Client feedback testimonials list"
    },
    "messages": {
      "schema": "Message",
      "description": "User message transmissions"
    },
    "analytics": {
      "schema": "PageView",
      "description": "Traffic statistics database"
    }
  }
}
